# Sentry client-side error tracking (optional; init skipped when unset)
# Baked in at build time — must be set before the build step runs.
VITE_SENTRY_DSN=""

# Only needed for cross-origin deployments (client on Vercel, server elsewhere, e.g. also
# Vercel but a different project/domain). Leave unset for same-origin deployments (Railway/
# Docker), which keep using relative /api paths via the Vite dev proxy or same-origin serving.
VITE_API_URL=""
