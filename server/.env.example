# PostgreSQL connection string (Railway Postgres plugin injects this automatically as DATABASE_URL)
DATABASE_URL="postgresql://user:password@localhost:5432/helpdesk?schema=public"

# Required
NODE_ENV="production"
BETTER_AUTH_SECRET="generate-a-random-secret"
BASE_URL="https://your-app.up.railway.app"
TRUSTED_ORIGINS="https://your-app.up.railway.app"
INBOUND_EMAIL_SECRET="generate-a-random-secret"

# Gmail outbound/inbound mail (see server/src/lib/mailer.ts, server/src/lib/imapPoll.ts)
GMAIL_USER=""
GMAIL_APP_PASSWORD=""

# Gemini API key used by @ai-sdk/google for ticket summarization/classification/auto-resolve
GOOGLE_GENERATIVE_AI_API_KEY=""

# Optional — Sentry server-side error tracking, skipped when unset
SENTRY_DSN=""

# Required only for the Vercel deployment (server/vercel.json + server/src/routes/cron.ts).
# Vercel automatically sends `Authorization: Bearer $CRON_SECRET` to Cron-triggered requests
# when this env var is set on the project — used to drain pg-boss queues + poll IMAP, since
# Vercel Functions can't run the persistent workers used by the Docker/Railway deployment.
CRON_SECRET=""

# Used by prisma/seed.ts to create the initial admin user
SEED_ADMIN_EMAIL=""
SEED_ADMIN_PASSWORD=""
SEED_ADMIN_ROLE="ADMIN"
